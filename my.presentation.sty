\gdef\beamer@transition{}
\gdef\beamer@transtime{}
\newcommand<>{\transition}[1][]{%
	\only#2{%
		\ifthenelse{\equal{#1}{}}{%
			\gdef\beamer@transition{true}%
			\gdef\beamer@transtime{}%
		}{%
			\gdef\beamer@transition{true}%
			\gdef\beamer@transtime{#1}%
		}%
	}%
	\ifthenelse{\equal{#1}{}}{%
		\animate#2%
	}{%
		\transduration#2{#1}%
	}%
}%


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Specify time used by frame

\newcounter{dumin}
\newcounter{dusec}
\newcommand*\addtime[1]{%
	\addtocounter{dusec}{#1}%
	\whiledo {\value{dusec} > 59}{%
		\stepcounter{dumin}%
		\addtocounter{dusec}{-60}%
	}%
}
\newcommand*\twoarabic[1]{\ifthenelse{\value{#1} > 9}{}{0}\arabic{#1}}
\newcommand*\printdu{\arabic{dumin}:\twoarabic{dusec}}
\newcommand*\pagetime[1]{%
  \setcounter{dumin}{\value{dumin}}%
  \setcounter{dusec}{\value{dusec}}%
  \addtime{#1}%
}
\newcommand*\frametime[1]{%
	\ifthenelse{\insertpagenumber=\insertframestartpage}{%
		\pagetime{#1}%
	}{}%
}


\gdef\beamer@frametime{0}
\define@key{beamerframe}{time}{%
  \gdef\beamer@frametime{#1}%
  %\frametime{#1}
}


