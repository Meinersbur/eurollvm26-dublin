	\ifthenelse{\equal{\beamer@transition}{true}}{%
		\writeimpressive{PageProps[\insertpagenumber] = dict.copy(AnimateSlide)}%
			\ifthenelse{\equal{\beamer@transtime}{}}{%
		}{%
			\writeimpressive{PageProps[\insertpagenumber]['transtime'] = \beamer@transtime}%
		}%
	}{%
		\ifthenelse{\equal{\insertframestartpage}{\insertframeendpage}}{%
			\writeimpressive{PageProps[\insertpagenumber] = dict.copy(FrameSingleSlide)}%
		}{%
			\ifthenelse{\equal{\insertframestartpage}{\insertpagenumber}}{%
				\writeimpressive{PageProps[\insertpagenumber] = dict.copy(FrameFirstSlide)}%
			}{%
				\ifthenelse{\equal{\insertframeendpage}{\insertpagenumber}}{%
					\writeimpressive{PageProps[\insertpagenumber] = dict.copy(FrameLastSlide)}%
				}{%
					\writeimpressive{PageProps[\insertpagenumber] = dict.copy(FrameInnerSlide)}%
				}%
			}%
		}%
	}%
%
	\gdef\beamer@transition{}%
