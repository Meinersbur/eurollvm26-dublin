\newcount\beamer@nextpagenumber

% Mechanism to store some slide transition note and display it on the PREVIOUS slide
\newcommand<>\slidenote[1]{%
  \only#2{\note{\beamer@writethispagenote{#1}}}% Such that it is output somewhere if only notes are generated, without preview
  \note#2[item]{#1}% So the note also appears on the regular notes page
}

\gdef\beamer@nextpagenote{}
\newcommand*\beamer@slidenote[2]{%
  \beamer@nextpagenumber=\c@page%
  \advance\beamer@nextpagenumber by 1\relax%
  \ifnum#1=\beamer@nextpagenumber%
    \gdef\beamer@nextpagenote{#2}%
  \fi%
}

\gdef\beamer@lastwrittenpagenote{}
%\newcommand*\beamerwritethispagenote[1]{\beamer@writethispagenote{#1}}
\newcommand*\beamer@writethispagenote[1]{%
%	\ifthenelse{\equal{#1}{}}{}{
		% Write slide notes
%		\ifthenelse{\equal{{\insertpagenumber}}{\beamer@lastwrittenpagenote}}{}{
\expandafter\addtocontents{nav}{\protect\headcommand{\protect\beamer@slidenote{\insertpagenumber}{#1}}}%
%			\gdef\beamer@lastwrittenpagenote{\insertpagenumber}%
%		}
%	}%
}


% Mechnism to store the page title into the .nav file so we know the future page's title
\gdef\beamer@nextpagetitle{}
\newcommand*\beamer@slidetitle[2]{%
  \beamer@nextpagenumber=\c@page%
  \advance\beamer@nextpagenumber by 1\relax%
  \ifnum#1=\beamer@nextpagenumber%
    \gdef\beamer@nextpagetitle{#2}%
  \fi%
}
%\newcommand*\beamerwritethispagetitle[1]{\beamer@writethispagetitle{#1}}
\newcommand*\beamer@writethispagetitle[1]{%
\expandafter\addtocontents{nav}{\protect\headcommand{\protect\beamer@slidetitle{\insertpagenumber}{#1}}}%
%			\gdef\beamer@lastwrittenpagenote{\insertpagenumber}%
}



\newcommand*{\minislide}{
	\node[inner sep=0,fit={(current page.north east) ($(current page.north east)!0.5!(current page.south west)$)},fill=black!5](previewback) {};
	\node[anchor=north east,inner sep=0](preview) at (current page.north east) {\includegraphics[scale=0.5,page=\insertpagenumber]{presentation-final}};
}
\setbeamertemplate{note page}{%
\frametime{\beamer@frametime}%
\gdef\beamer@frametime{0}%
\beamer@writethispagetitle{\insertframetitle}% Remember title for the next run
%\begin{tikzpicture}[overlay]%
%\node {\insertslideintonotes{1}};
%\end{tikzpicture}%
%
% Beamer with notes activated uses \nofiles, making positioning by [remember picture] difficult
% We position the cursor at the top left of the page such that with \nofiles and without \nofiles the relative position to the page is the same
% Alternatively, state of \nofiles can be queries using \if@filesw
\vskip\paperheight%
\hskip-\Gm@lmargin%
\insertslideintonotes{1}
	\begin{tikzpicture}[remember picture,overlay]%
		\minislide
%		\node[anchor=north east,inner sep=0] (preview) at (current page.north east) {%
%\insertslideintonotesat{0.5}
%};
		\path[fill=white] (current page.north west) rectangle (current page.south east -| preview.west);
		\path[fill=white] (current page.north west |- preview.south) rectangle (current page.south east);
%
		\coordinate (right titles) at ($(preview.west) - (3mm,0)$);
		\node[anchor=north west,text width=61mm] (title) at (current page.north west) {\insertshorttitle[width=61mm]};
		\node[anchor=north west,text width=57mm] (section) at ($(title.south west) + (4mm,0)$) {\insertsection};
		\node[anchor=north west,text width=53mm] (subsection) at ($(section.south west) + (4mm,0)$) {\insertsubsection};
		\node[anchor=north west,text width=49mm] (frametitle) at ($(subsection.south west) + (4mm,0)$) {\textbf{\insertshortframetitle[width=49mm]}};
%
		\draw ($(title.south west) + (2mm,0)$) |- (section);
		\draw ($(section.south west) + (2mm,0)$) |- (subsection);
		\draw ($(subsection.south west) + (2mm,0)$) |- (frametitle);
%
		\node[anchor=north west,text width=\paperwidth] at (current page.west |- preview.south) {\insertnote};
%
		\node[anchor=south east] (duration) at (current page.south east) {\huge \printdu};
		\node[anchor=south east] at (duration.north east) {(\insertframestartpage-\insertpagenumber-\insertframeendpage) \insertframenumber/\inserttotalframenumber };
%
		\ifthenelse{\equal{\beamer@nextpagenote}{}}{%
			\ifthenelse{\equal{\beamer@nextpagetitle}{}}{%
			}{%
				\node[anchor=base west] at ($(current page.south west) + (0,1mm)$) {\Large \beamer@nextpagetitle};%
			}%
		}{%
			\node[anchor=base west] at ($(current page.south west) + (0,1mm)$) {\Large \beamer@nextpagenote};%
		}%
	\end{tikzpicture}%
	\gdef\beamer@nextpagenote{}%
	\gdef\beamer@nextpagetitle{}%
}



