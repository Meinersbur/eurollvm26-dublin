\makeatletter
\newcounter{subseccount}

% 1. Create a label at the exact moment a subsection starts
\AtBeginSubsection[]{
  \stepcounter{subseccount}
  % We use \immediate to ensure the page number is captured RIGHT NOW
  \immediate\write\@auxout{\string\newlabel{subseclabel:\thesubseccount}{{\thesubseccount}{\thepage}}}
}

% 2. Create a "dummy" label at the very end of the document
\AtEndDocument{
  \stepcounter{subseccount}
  \immediate\write\@auxout{\string\newlabel{subseclabel:\thesubseccount}{{\thesubseccount}{\thepage}}}
}





