\renewcommand<>*{\mark}[2][yellow]{%
\ifmmode%
  \alt#3{\fboxsep0pt{}\colorbox{#1}{\vphantom{$\mid_1^1$}$#2$}}{\vphantom{\mid_1^1}#2}%
\else%
  \alt#3{\fboxsep0pt{}\colorbox{#1}{\vphantom{$\mid_1^1$}#2}}{\vphantom{$\mid_1^1$}#2}%
\fi%
}


