% Setzt ein tikz-coordinate an diese Stelle
% \anchor[placement t()op, b(ottom), m(iddle) or ()baseline)]{node name}
\newcommand{\anchor}[2][]{%
\ifthenelse{\equal{#1}{t}}{%
        \tikz[remember picture,overlay,baseline=(#2 anchor.base)] {\node[outer sep=0pt,inner sep=0pt](#2 anchor){\vphantom{MX}}; \coordinate(#2) at (#2 anchor.north);}%
}{%
        \ifthenelse{\equal{#1}{b}}{%
                        \tikz[remember picture,overlay,baseline=(#2 anchor.base)] {\node[outer sep=0pt,inner sep=0pt](#2 anchor){\vphantom{jp}}; \coordinate(#2) at (#2 anchor.south);}%
        }{%
                \ifthenelse{\equal{#1}{m}}{%
                        \tikz[remember picture,overlay,baseline=(#2 anchor.base)] {\node[outer sep=0pt,inner sep=0pt](#2 anchor){\vphantom{MXjp}}; \coordinate(#2) at (#2 anchor.center);}%
                }{%
                        \tikz[remember picture,overlay,baseline=(#2)] {\coordinate (#2);}%
                }%
        }%
}%
}

