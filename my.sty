\newcommand*{\@my@elaboration}{false}
\pgfkeys{/my/.cd,elaboration/.value forbidden,elaboration/.code=\renewcommand*{\@my@elaboration}{true}}

\newcommand*{\@my@titlepage}{false}
\pgfkeys{/my/.cd,titlepage/.value forbidden,titlepage/.code=\renewcommand*{\@my@titlepage}{true}}

\newcommand*{\@my@presentation}{false}
\pgfkeys{/my/.cd,presentation/.value forbidden,presentation/.code=\renewcommand*{\@my@presentation}{true}}

\newcommand*{\@my@notes}{false}
\pgfkeys{/my/.cd,notes/.value forbidden,notes/.code=\renewcommand*{\@my@notes}{true}}

\pgfkeys{/my/language/.value required,/my/language/.default=english}
\pgfkeys{/my/english/.style={language=american}}
\pgfkeys{/my/german/.style={language=ngerman}}
\pgfkeys{/my/french/.style={language=french}}
\newcommand*{\@my@language}{english}
\pgfkeys{/my/language/.code=\renewcommand*{\@my@language}{#1}} % For compatibility

\newcommand*{\@my@institute}{}
\pgfkeys{/my/.cd,institute/.code=\renewcommand*{\@my@institute}{#1}}

\newcommand*{\@my@shortinstitute}{}
\pgfkeys{/my/.cd,shortinstitute/.code=\renewcommand*{\@my@shortinstitute}{#1}}

\newcommand*{\@my@subject}{}
\pgfkeys{/my/.cd,subject/.code=\renewcommand*{\@my@subject}{#1}}

\newcommand*{\@my@publishers}{}
\pgfkeys{/my/.cd,publishers/.code=\renewcommand*{\@my@publishers}{#1}}

\newcommand*{\@my@keywords}{}
\pgfkeys{/my/.cd,keywords/.code=\renewcommand*{\@my@keywords}{#1}}

\newcommand*\@my@purpose{}
\pgfkeys{/my/.cd,purpose/.code=\renewcommand*\@my@purpose{#1}}
\newcommand*\thepurpose{\@my@purpose}

\ProcessPgfOptions{/my}

\newcommand*{\ifelaboration}[1]{\ifthenelse{\equal{\@my@elaboration}{true}}{#1}{}}
